# Forecast Studio — example environment file.
# Copy to backend/.env (backend) and frontend/.env.local (frontend).
# Never commit real secrets.

# ---------- Backend (FastAPI) ----------
# Comma-separated CORS allowlist for the frontend.
CORS_ORIGINS=http://localhost:3000

# SQL generation (Milestone 4).
# The default "local" backend is free, deterministic, and offline — no API key
# and no internet needed. A real LLM provider can be added later behind the
# same interface.
SQL_GENERATOR_BACKEND=local

# Database URLs — added in later milestones. Leave blank for now.
# METADATA_DATABASE_URL=
# DEMO_DATABASE_URL=

# ---------- Frontend (Next.js) ----------
# Base URL the browser uses to reach the backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
