# Forecast Studio — example environment file.
# Copy to backend/.env (backend) and frontend/.env.local (frontend).
# Never commit real secrets.

# ---------- Backend (FastAPI) ----------
# Comma-separated CORS allowlist for the frontend origin(s).
# Local dev: http://localhost:3000
# Production: set to your deployed frontend URL, e.g.
#   CORS_ORIGINS=https://forecast-studio.vercel.app
CORS_ORIGINS=http://localhost:3000

# PORT is injected by most hosts (Render/Railway/Fly); the app honors it.
# Locally you can ignore this (defaults to 8000).
# PORT=8000

# SQL generation provider: "local" (default) or "groq".
# "local" is free, deterministic, and offline — no API key, no internet.
# "groq" uses the Groq API for generation and falls back to local on any error.
SQL_GENERATOR_PROVIDER=local

# Groq — BACKEND-ONLY secret. Never prefix with NEXT_PUBLIC and never expose it
# to the browser. Only used when SQL_GENERATOR_PROVIDER=groq.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Query history + semantic-dedup cache.
# CACHE_ENABLED: set false to disable the cache (always regenerate SQL).
# SEMANTIC_CACHE_THRESHOLD: Jaccard similarity (0-1) a near-duplicate question
#   must reach to reuse cached SQL (same intent, connection, schema, verified).
CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.85

# Optional Postgres demo (e.g. Neon). Enables connection_id "demo_postgres".
# Leave both blank to run SQLite-only (connection_id "demo" / "demo_sqlite").
# POSTGRES_DATABASE_URL takes precedence over DATABASE_URL when both are set.
# Example: postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
POSTGRES_DATABASE_URL=
DATABASE_URL=

# ---------- Frontend (Next.js) — put this in frontend/.env.local ----------
# Base URL the browser uses to reach the backend.
# Local dev: http://localhost:8000
# Production: your deployed backend URL, e.g.
#   NEXT_PUBLIC_API_BASE_URL=https://forecast-studio-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
